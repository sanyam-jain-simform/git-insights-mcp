{
  "name": "git-insights-mcp",
  "version": "0.1.0",
  "description": "A local-only MCP server that exposes git repo history, diffs, and status as tools for LLM clients.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "git-insights-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "lint": "eslint src",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "simple-git": "^3.27.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.4",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.63.0"
  }
}
